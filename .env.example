# Copy this file to .env. Never commit the populated .env file.
OPENROUTER_API_KEY=

# Cheap multimodal transport baseline; replace it for quality calibration.
INSPECT_EVAL_MODEL=openrouter/openai/gpt-4o-mini

# Keep local Inspect logs and media out of Git.
INSPECT_LOG_DIR=.runs/inspect
INSPECT_EVAL_MAX_RETRIES=3
INSPECT_EVAL_MAX_CONNECTIONS=4

# Optional OpenRouter override. The default is https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=

# Direct OpenAI alternative:
# OPENAI_API_KEY=
# INSPECT_EVAL_MODEL=openai/model-name

# Generic OpenAI-compatible alternative. Replace ACME with the provider name.
# ACME_API_KEY=
# ACME_BASE_URL=https://api.example.com/v1
# INSPECT_EVAL_MODEL=openai-api/acme/model-name
